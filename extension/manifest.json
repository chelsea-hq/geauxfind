{
  "manifest_version": 3,
  "name": "GeauxFind Thread Capture",
  "version": "0.1.0",
  "description": "One-click capture of Facebook threads into GeauxFind community recs.",
  "icons": {
    "32": "icons/icon-32.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "GeauxFind — Capture this thread",
    "default_popup": "popup.html",
    "default_icon": {
      "32": "icons/icon-32.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "*://*.facebook.com/*",
    "*://geauxfind.vercel.app/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.facebook.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
