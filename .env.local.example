# GeauxFind local environment example
# Copy this file to .env.local and fill in your values

# API key required by POST /api/community/ingest
GEAUXFIND_INGEST_KEY=replace-with-a-long-random-secret

# Optional default used by scripts/discord-dump-watcher.mjs
GEAUXFIND_INGEST_URL=http://localhost:3000/api/community/ingest
